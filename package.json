{
  "name": "distributed-job-queue",
  "version": "1.0.0",
  "description": "Distributed job queue system using BullMQ, Redis, and MongoDB",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "workers": "node src/workers/index.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand --forceExit"
  },
  "dependencies": {
    "bullmq": "^5.1.1",
    "mongoose": "^8.1.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "@bull-board/express": "^5.14.3",
    "@bull-board/api": "^5.14.3",
    "dotenv": "^16.4.1",
    "winston": "^3.11.0",
    "joi": "^17.12.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "uuid": "^9.0.0",
    "date-fns": "^3.3.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4",
    "ioredis-mock": "^8.9.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["src/**/*.js"],
    "coverageDirectory": "coverage",
    "setupFilesAfterFramework": []
  }
}
